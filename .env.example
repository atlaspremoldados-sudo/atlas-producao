# .env.example
# Copie este arquivo para .env.local e preencha com seus valores.
# IMPORTANTE: .env.local NUNCA deve ser comitado (já está no .gitignore).

# ============================================================================
# SUPABASE (obrigatório)
# ============================================================================
# Painel: https://supabase.com/dashboard/project/whojujjnpaklidkfkpbj
VITE_SUPABASE_URL=https://whojujjnpaklidkfkpbj.supabase.co

# anon public key (pode ficar no front; RLS é a defesa real)
# Pegar em: Settings → API → anon public
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# FORTEPLUS (futuro — quando integração estiver pronta)
# ============================================================================
# IMPORTANTE: o JWT do Forteplus NAO vai no front. Vai como Secret na
# Edge Function do Supabase (supabase secrets set FORTEPLUS_JWT=...).
# Estas linhas são apenas para uso em scripts/CLI locais.
#
# Documentação completa em:
#   /05-INTEGRACAO-FORTEPLUS/ (pasta de docs do projeto)
#
# FORTEPLUS_API_URL=https://api.forteplus.com.br/api/v1
# FORTEPLUS_JWT=eyJ0eXAiOiJKV1QiLCJhbGciOi...
